{
  "name": "retro-napolitan",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "2D pixel turn-based roguelike boilerplate. Fork it, replace src/content/, ship.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
